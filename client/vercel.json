{
    "version": 2,
    "builds": [
        {
        "src": "package.json",
        "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
        "source": "/api/(.*)",
        "destination": "/server/dist/index.js"
        }
    ],
    "routes": [
        {
        "src": "/(.*)",
        "dest": "/index.html"
        }
    ]
}